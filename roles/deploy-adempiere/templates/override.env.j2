# Example override file for local adjustments.
# This file is generated by Ansible.
# Do not edit manually.

# Host and network
HOST_IP={{ ansible_facts['default_ipv4']['address'] }}

# Postgres — bound to localhost only so the port is NOT reachable from the internet.
# Docker Compose interprets "127.0.0.1:<port>:<container_port>", which limits access
# to processes on the host itself (e.g. SSH-tunnelled admin tools).
# CVE note: exposing 0.0.0.0:5432 was the entry point for a cryptominer infection
# on both Contabo test servers (2026-05-09).
POSTGRES_EXTERNAL_PORT=127.0.0.1:{{ postgres_external_port }}
POSTGRES_PASSWORD={{ postgres_password }}
